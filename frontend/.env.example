VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Set to "true" to render demo polygons from public/data/active_fires.geojson
# instead of fetching enriched fires through the backend. Use for the demo run.
VITE_USE_MOCK_FIRES=false

# Backend REST API base URL — `RestApiUrl` output from the FrontendStack.
# fires.js fetches `${VITE_API_URL}fires`. Trailing slash on the CDK output is
# fine (fires.js tolerates either form). Unset = mock-only mode.
VITE_API_URL=

# Live update channel — fire_updated + alert_sent events from the backend.
# Leave unset for local dev (frontend falls back to 30s polling alone).
VITE_WS_URL=
